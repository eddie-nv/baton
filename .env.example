# ─────────────────────────────────────────────────────────────
# Baton environment variables
# ─────────────────────────────────────────────────────────────

# Backend
# Where the backend HTTP server listens.
BATON_PORT=3000

# Redis connection string. Default points at the docker-compose service.
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# MCP shim (runs on user's laptop / IDE host)
# ─────────────────────────────────────────────────────────────

# Base URL of the Baton backend. Local dev: http://localhost:3000
# Prod: https://mcp.baton
BATON_API_URL=http://localhost:3000

# Room bearer capability. Treat like a secret — anyone with this
# can read/write the room. Created via create_room.
BATON_ROOM_ID=

# Actor identity for events the shim emits (e.g. "alice@claude-code").
BATON_ACTOR_ID=

# Default feature_id if the caller omits one. Normalized git branch
# name, e.g. feat_payments_idempotency.
BATON_FEATURE_ID=
